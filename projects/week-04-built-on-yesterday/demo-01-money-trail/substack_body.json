                "class": null
              }
            }
          ],
          "text": "Summer into AI 2026"
        },
        {
          "type": "text",
          "text": " hosted by "
        },
        {
          "type": "text",
          "marks": [
            {
              "type": "link",
              "attrs": {
                "href": "https://advisoryhour.substack.com",
                "target": "_blank",
                "rel": "noopener noreferrer nofollow",
                "class": null
              }
            }
          ],
          "text": "@advisoryhour"
        },
        {
          "type": "text",
          "text": " — theme: Built on Yesterday."
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "Dark Money Map showed you which PACs donated to a candidate. Money Trail goes three layers deeper — it traces PAC donors to discover who funds the funders, renders the whole network as a live D3 force graph, and then runs Claude extended thinking to surface the hidden patterns a human analyst would spend days finding."
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "Worth noting alongside this: "
        },
        {
          "type": "text",
          "marks": [
            {
              "type": "link",
              "attrs": {
                "href": "https://advisoryhour.substack.com",
                "target": "_blank",
                "rel": "noopener noreferrer nofollow",
                "class": null
              }
            }
          ],
          "text": "Other week-4 entries"
        },
        {
          "type": "text",
          "text": " took the theme as a prompt to polish UI; Money Trail took it as permission to rethink what the data itself reveals"
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "How the AI works"
        }
      ]
    },
    {
      "type": "bullet_list",
      "content": [
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "marks": [
                    {
                      "type": "strong"
                    }
                  ],
                  "text": "Three-layer PAC traversal"
                },
                {
                  "type": "text",
                  "text": " — the FEC API returns each contributor's ID. Any ID starting with 'C' is itself a committee; the demo auto-fetches that committee's donors too, building a donor → PAC → candidate graph in one pass."
                }
              ]
            }
          ]
        },
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "marks": [
                    {
                      "type": "strong"
                    }
                  ],
                  "text": "Claude extended thinking as oracle"
                },
                {
                  "type": "text",
                  "text": " — after the graph loads, Claude reasons step-by-step through the full network data using 10,000 thinking tokens, then uses a highlight_nodes tool to surface the most suspicious clusters. You watch the reasoning happen in real time."
                }
              ]
            }
          ]
        },
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "marks": [
                    {
                      "type": "strong"
                    }
                  ],
                  "text": "Compare mode"
                },
                {
                  "type": "text",
                  "text": " — load two politicians side by side and ask Claude to identify shared donors, cross-network PAC patterns, and who is really pulling both strings."
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "How to play"
        }
      ]
    },
    {
      "type": "bullet_list",
      "content": [
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "text": "Enter any politician's name and click TRACE."
                }
              ]
            }
          ]
        },
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "text": "Watch the force graph populate — gold diamonds are PACs, circles are individual donors, dashed edges mean 'funds through an intermediary.'"
                }
              ]
            }
          ]
        },
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "text": "Click "
                },
                {
                  "type": "text",
                  "marks": [
                    {
                      "type": "strong"
                    }
                  ],
                  "text": "ASK THE ORACLE"
                },
                {
                  "type": "text",
                  "text": " to stream Claude's extended thinking analysis. The reasoning panel expands automatically."
                }
              ]
            }
          ]
        },
        {
          "type": "list_item",
          "content": [
            {
              "type": "paragraph",
              "attrs": {
                "textAlign": null
              },
              "content": [
                {
                  "type": "text",
                  "text": "Try compare mode: enter two candidates and see which donors appear in both networks."
                }
              ]
            }
          ]
        }
      ]
    },
