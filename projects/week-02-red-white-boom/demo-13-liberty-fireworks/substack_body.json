  ]},
  {"type":"horizontal_rule"},
  {"type":"paragraph","attrs":{"textAlign":null},"content":[
    {"type":"text","marks":[{"type":"em"}],"text":"Summer into AI 2026 · Week 2: Red, White & Boom"}
  ]}
]}